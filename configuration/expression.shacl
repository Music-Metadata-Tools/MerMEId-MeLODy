  melod:MusicIncipit
  a               sh:NodeShape ;
  rdfs:label      "Incipit" ;
  # To add: Ontology with clefs
  sh:property   [ sh:description  "Clef of the plaine and easy code of the incipit" ;
                  sh:name         "PAE clef" ;
                  sh:path         melod:clef ;
                  sh:maxCount     1 ;
                  sh:in           ("G-2" "g-2" "C-3" "C+3" "F-4")
                ] ;
  # To add: Ontology with key signatures
  sh:property   [ sh:description  "Keysig of the plaine and easy code of the incipit" ;
                  sh:name         "PAE keysig" ;
                  sh:path         melod:keysig ;
                  sh:maxCount     1 ;
                  sh:in           ("xFC" "bBEA" "xF")
                ] ;
  sh:property   [ sh:description  "Timesig of the plaine and easy code of the incipit" ;
                  sh:name         "PAE timesig" ;
                  sh:path         melod:timesig ;
                  sh:maxCount     1 ;
                  sh:in           ("2/4" "3/4" "4/4" "3" "c" "c3" "c/")
                ] ;
  sh:property   [ sh:description  "Data of the plaine and easy code of the incipit" ;
                  sh:name         "PAE data" ;
                  sh:path         melod:incipitData ;
                  sh:maxCount     1
                ] ;
  sh:property   [ sh:description  "Text of the Incipit" ;
                  sh:name         "Incipit Text" ;
                  sh:path         melod:incipitText ;
                  dash:singleLine false ;
                  sh:minCount     0 ;
                  sh:maxCount     1
                ] ;        
  sh:targetClass  schema:MusicIncipit .


  # add a label to the license IRIs
<https://mei-metadata.org/roles/Composer> rdfs:label "Composer" .
<https://mei-metadata.org/roles/Lyricist> rdfs:label "Lyricist" .
<https://mei-metadata.org/roles/Arranger> rdfs:label "Arranger" .