@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix melod: <https://mei-metadata.org/> .
@prefix owl: <https://www.w3.org/TR/owl-ref/> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cidoc: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mus: <http://data.doremus.org/ontology#> .

melod:Expression
  a               sh:NodeShape, rdfs:Class ;
  sh:property   [ sh:name "Title" ;
                  sh:minCount 0 ;
                  sh:node melod:Title ;
                  sh:path melod:hasTitle
                ] ;
#  sh:property   [ sh:description "Expression title, e.g. 'Version 1'" ;
#                  sh:name "Title" ;
#                  sh:minCount 0 ;
#                  sh:maxCount 1;
#                  sh:path schema:name
#                ] ;
  sh:property   [ sh:description "Type of the expression" ;
                  sh:name "Type" ;
                  sh:minCount 0 ;
                  sh:path schema:about
                ] ;
  sh:property   [ sh:description "Link to an external web resource" ;
                  sh:name "Link" ;
                  sh:minCount 0 ;
                  sh:path owl:sameAs ;
                  sh:nodeKind sh:IRI
                ] ;
  sh:property   [ sh:description "Index identifiers" ;
                  sh:name "Index identifiers" ;
                  sh:minCount 0 ;
                  sh:path schema:identifier ;
                  sh:node melod:Identifier
                ] ;
  sh:property   [ sh:description "Language usage" ;
                  sh:datatype rdf:langString ;
                  sh:name "Language" ;
                  sh:minCount 0 ;
                  sh:maxCount 1 ;
                  sh:path melod:langUsage
                ] ;
  sh:property   [ sh:description "Contributor of the expression version (Arranger or text author)" ;
                  sh:name "Contributor" ;
                  sh:minCount 0 ;
                  sh:node melod:Contributor ;
                  sh:path melod:hasContributor
                ] ;
  sh:property   [ sh:description "Date of the creation of the expression" ;
                  sh:name "Creation date" ;
                  sh:minCount 0 ;
                  sh:maxCount 1 ;
                  sh:path schema:dateCreated ;
                  sh:or (
                    [ sh:datatype  xsd:date ; rdfs:label "Single date" ]
                    [ sh:node melod:Date ; rdfs:label "Date span" ]
                  )
                ] ;
  sh:property   [ sh:description "Place of the creation of the expression" ;
                  sh:name "Creation place" ;
                  sh:minCount 0 ;
                  sh:maxCount 1 ;
                  sh:path schema:locationCreated ;
                  sh:defaultValue "https://mei-metadata.org/places/" ;
                  sh:pattern      "^https://mei-metadata.org/places/\\d{8}" ;
                  sh:nodeKind sh:IRI
                ] ;
  sh:property   [ sh:description "First performance of the expression" ;
                  sh:name "First performance" ;
                  sh:minCount 0 ;
                  sh:maxCount 1 ;
                  sh:path schema:firstPerformance ;
                  sh:defaultValue "https://mei-metadata.org/performances/" ;
                  sh:pattern      "^https://mei-metadata.org/performances/\\d{8}" ;
                  sh:nodeKind sh:IRI
                ] ;
  sh:property   [ sh:description "History of the creation of the expression" ;
                  sh:name "Creation history" ;
                  sh:minCount 0 ;
                  sh:path melod:history ;
                  sh:defaultValue "https://mei-metadata.org/events/" ;
                  sh:pattern      "^https://mei-metadata.org/events/\\d{8}" ;
                  sh:nodeKind sh:IRI
                ] ;
  sh:property   [ sh:description "Extent of the written music e.g. 50 T." ;
                  sh:name "Extent" ;
                  sh:minCount 0 ;
                  sh:maxCount 1;
                  sh:path melod:extent
                ] ;
  sh:property   [ sh:description "Allegro" ;
                  sh:name "Tempo" ;
                  sh:minCount 0 ;
                  sh:maxCount 1;
                  sh:path melod:tempo
                ] ;
  sh:property   [ sh:description "d minor modulierend" ;
                  sh:name "Key" ;
                  sh:minCount 0 ;
                  sh:maxCount 1 ;
                  sh:node melod:Key ;
                  sh:path melod:hasKey
                ] ;
  sh:property   [ sh:description "3/4 or c" ;
                  sh:name "Meter" ;
                  sh:minCount 0 ;
                  sh:maxCount 1 ;
                  sh:node melod:Meter ;
                  sh:path melod:hasMeter
                ] ;
  sh:property   [ sh:description "01:23:00 or 4'33 or approx. 10 minutes" ;
                  sh:name "Performance duration" ;
                  sh:minCount 0 ;
                  sh:maxCount 1;
                  sh:path melod:duration
                ] ;
  sh:property   [ sh:description "Information about mensuration" ;
                  sh:name "Mensuration" ;
                  sh:minCount 0 ;
                  sh:maxCount 1;
                  sh:path melod:mensuration
                ] ;
  sh:property   [ sh:description  "Performance resource" ;
                  sh:name         "Performance resources" ;
                  sh:nodeKind         sh:IRI ;
                  sh:defaultValue "https://mei-metadata.org/instrumentation/" ;
                  sh:pattern      "^https://mei-metadata.org/instrumentation/\\d{8}" ;
                  sh:path         mus:U12_has_casting
                ] ;
  sh:property   [ sh:description  "Incipit" ;
                  sh:name         "Incipits" ;
                  sh:node         melod:MusicIncipit ;
                  sh:path         schema:includedComposition
                ] ;
  sh:property   [ sh:description "Individual Piece of a Expression. E.g. movements, sections, scenes, acts" ;
                  sh:name "Components" ;
                  sh:minCount 0 ;
                  sh:defaultValue "https://mei-metadata.org/expressions/" ;
                  sh:pattern      "^https://mei-metadata.org/expressions/\\d{8}" ;
                  sh:nodeKind sh:IRI ;
                  sh:path schema:includedComposition
                ] ;
  sh:property   [ sh:description "Additional information related to the expression" ;
                  sh:name "Comment" ;
                  dash:singleLine false ;
                  sh:path schema:comment
                ] ;
  sh:property   [ sh:description "Bibliography" ;
                  sh:name "Bibliography" ;
                  sh:minCount 0 ;
                  sh:defaultValue "https://mei-metadata.org/bibliography/" ;
                  sh:pattern      "^https://mei-metadata.org/bibliography/\\d{8}" ;
                  sh:nodeKind sh:IRI ;
                  sh:path schema:citation
                ] ;
  sh:targetClass  melod:Expression .

melod:Title
  a               sh:NodeShape ;
  sh:property   [ sh:description "Expression title, e.g. 'Version 1'" ;
                  sh:name      "Title" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      schema:name
                ] ;
  sh:property   [ sh:name      "Type" ;
                  sh:minCount  0 ;
                  sh:maxCount  1 ;
                  sh:path      melod:titleType
                ] .

melod:Identifier
  a               sh:NodeShape ;

  sh:property   [ sh:description "e.g. TVWV" ;
                  sh:name      "Name of Identifier" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      schema:name
                ] ;
  sh:property   [ sh:description "e.g. abc" ;
                  sh:name      "Value" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:datatype  xsd:string ;
                  sh:path      owl:hasValue
                ] .

melod:Date
  a               sh:NodeShape ;
  sh:property   [ sh:name      "Start date" ;
                  sh:minCount  1 ;
                  sh:path      schema:startDate ;
                  sh:datatype  xsd:date
                ] ;
  sh:property   [ sh:name      "End date" ;
                  sh:minCount  1 ;
                  sh:path      schema:endDate ;
                  sh:datatype  xsd:date
                ] ;
  sh:targetClass  schema:Date .

melod:Contributor
  a               sh:NodeShape ;
  rdfs:label      "Contributors" ;
  sh:property   [ sh:maxCount  1 ;
                  sh:minCount  1 ;
                  sh:path      melod:agent ;
                  sh:or (
                    [ sh:node melod:Person ; rdfs:label "Person" ]
                    [ sh:node melod:Institution ; rdfs:label "Institution" ]
                  )
                ] ;
  sh:property   [ sh:description  "Role of the contribution" ;
                  sh:name         "Role" ;
                  sh:path         melod:role ;
                  sh:nodeKind     sh:IRI ;
                  sh:in (
                    # see below how labels are added to the list entries
                    <https://mei-metadata.org/roles/Composer>
                    <https://mei-metadata.org/roles/Arranger>
                    <https://mei-metadata.org/roles/Lyricist>
                  ) ;
                  sh:maxCount     1 ;
                  sh:minCount     1
                ] ;              
  sh:targetClass  melod:Contribution .

melod:Person
  a               sh:NodeShape ;
  rdfs:label      "Person" ;
  sh:property   [ sh:maxCount     1 ;
                  sh:minCount     1 ;
                  sh:name         "IRI" ;
                  sh:path         melod:iri ;
                  sh:defaultValue "https://mei-metadata.org/persons/" ;
                  sh:pattern      "^https://mei-metadata.org/persons/\\d{8}" ;
                  sh:nodeKind sh:IRI ;
                ] ;
  sh:targetClass  melod:Person .

melod:Organisation
  a               sh:NodeShape ;
  rdfs:label      "Organisation" ;
  sh:property   [ sh:maxCount     1 ;
                  sh:minCount     1 ;
                  sh:name         "IRI" ;
                  sh:path         melod:iri ;
                  sh:defaultValue "https://mei-metadata.org/institutions/" ;
                  sh:pattern      "^https://mei-metadata.org/institutions/\\d{8}" ;
                  sh:nodeKind sh:IRI ;
                ] ;
  sh:targetClass  melod:Organisation .

melod:Key
  a               sh:NodeShape ;
  sh:property   [ sh:description "Pname" ;
                  sh:name      "Pname" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      melod:pname ;
                  sh:in ( "c" "d" "e" "f" "g" "a" "b")
                ] ;
  sh:property   [ sh:name      "Mode" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      melod:mode ;
                  sh:in ( "major" "minor" )
                ] .

melod:Meter
  a               sh:NodeShape ;
  sh:property   [ sh:description "Count" ;
                  sh:name      "Count" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      melod:count ;
                  sh:datatype  xsd:integer
                ] ;
  sh:property   [ sh:name      "Unit" ;
                  sh:minCount  0 ;
                  sh:maxCount  1 ;
                  sh:path      melod:unit ;
                  sh:datatype  xsd:integer
                ] .

