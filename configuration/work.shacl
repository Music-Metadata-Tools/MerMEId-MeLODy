melod:Title
  a               sh:NodeShape ;
  sh:property   [ sh:description "Title of the work" ;
                  sh:name      "Title" ;
                  sh:languageIn   ( "en" "de" ) ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      schema:name
                ] ;
  sh:property   [ sh:name      "Type of title" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      melod:titleType ;
                  sh:in ( "original" "alternative" )
                ] .

melod:Contributor
  a               sh:NodeShape ;
  #owl:imports     "<https://mei-metadata.org/roles/ontology.ttl>" ;
  sh:property   [ sh:name "IRI" ;
                  sh:description "IRI of a contributiong person" ;
                  sh:minCount  0 ;
                  sh:maxCount  1 ;
                  sh:nodeKind  sh:IRI ;
                  sh:path owl:sameAs
                ] ;
  sh:property   [ sh:name      "Role" ;
                  sh:minCount  0 ;
                  sh:path      melod:hadRole ;
                  sh:class     melod:Role
                ] .

melod:Identifier
  a               sh:NodeShape ;
  sh:property   [ sh:description "e.g. abc" ;
                  sh:name      "Value" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:datatype  xsd:string ;
                  sh:path      owl:hasValue
                ] ;
  sh:property   [ sh:description "e.g. TVWV" ;
                  sh:name      "Name of Identifier" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      schema:name
                ] .

melod:Date
  a               sh:NodeShape ;
  sh:property   [ sh:name      "Date type" ;
                  sh:minCount  1 ;
                  sh:path      melod:dateType ;
                  sh:or (
                    [ sh:node melod:singleDate ; rdfs:label "Single date" ]
                    [ sh:node melod:dateSpan ; rdfs:label "Date span" ]
                  )
                ] .

melod:singleDate
  a               sh:NodeShape ;
  sh:property   [ sh:name      "Single date" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:datatype  xsd:date ;
                  sh:path      owl:hasValue
                ] .

melod:dateSpan
  a               sh:NodeShape ;
  sh:property   [ sh:name      "Date span" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:datatype  xsd:date ;
                  sh:path      owl:hasValue
                ] ;
  sh:property   [ sh:name      "Date context" ;
                  sh:minCount  1 ;
                  sh:maxCount  1 ;
                  sh:path      melod:dateContext ;
                  sh:in ( "Start" "End" "Not before" "Not after" )
                ] .


melod:Arranger rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "arranger"@en .

melod:Author rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "author"@en .

melod:Composer rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "composer"@en .

melod:Contributor rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "contributor"@en .

melod:Editor rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "editor"@en .

melod:Funder rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "funder"@en .

melod:Librettist rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "librettist"@en .

melod:Lyricist rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "lyricist"@en .

melod:Sponsor rdf:type owl:NamedIndividual ,
        melod:Role ;
        skos:prefLabel "sponsor"@en .
