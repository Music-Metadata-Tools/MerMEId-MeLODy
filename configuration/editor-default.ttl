@prefix melod: <https://mei-metadata.org/> .
@prefix melod_ui: <https://mei-metadata.org/ui/> .
@prefix schema: <http://schema.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# The URL for entity shapes definition. It can be customized.
melod:EntityShapesDefinition schema:url <melod:ontologies/editor-default.ttl> .

# TODO: The base IRI for values subject. It can be customized.
# When it is not set, the editor uses an URN like this <urn:uuid:1081008>.

# List of entity types. It can be customized as follows:
# 1. types can be added or removed;
# 2. for an existing entity, rdfs:label can be changed;
# 3. for an existing entity, melod_ui:entity_folder_name can be changed;
# 4. for an existing entity, melod_ui:shacl_file_location can be changed (it can be a relative path, or an URL).
melod:Place a melod:Entity ;
    rdfs:label "Place"@en ;
    melod_ui:entity_folder_name "places" ;
    melod_ui:shacl_file_location "configuration/place.shacl" .
melod:Venue a melod:Entity ;
    rdfs:label "Venue"@en ;
    melod_ui:entity_folder_name "venues" ;
    melod_ui:shacl_file_location "configuration/venue.shacl" .
melod:Person a melod:Entity ;
    rdfs:label "Person"@en ;
    melod_ui:entity_folder_name "persons" ;
    melod_ui:shacl_file_location "configuration/person.shacl" .
melod:Institution a melod:Entity ;
    rdfs:label "Institution"@en ;
    melod_ui:entity_folder_name "institutions" ;
    melod_ui:shacl_file_location "configuration/institution.shacl" .
melod:Bibliography a melod:Entity ;
    rdfs:label "Bibliography"@en ;
    melod_ui:entity_folder_name "bibliography" ;
    melod_ui:shacl_file_location "configuration/bibliography.shacl" .
melod:Event a melod:Entity ;
    rdfs:label "Event"@en ;
    melod_ui:entity_folder_name "events" ;
    melod_ui:shacl_file_location "configuration/event.shacl" .
melod:PerformanceEvent a melod:Entity ;
    rdfs:label "Performance Event"@en ;
    melod_ui:entity_folder_name "performanceEvents" ;
    melod_ui:shacl_file_location "configuration/performanceEvent.shacl" .
melod:Manifestation a melod:Entity ;
    rdfs:label "Manifestation"@en ;
    melod_ui:entity_folder_name "manifestations" ;
    melod_ui:shacl_file_location "configuration/manifestation.shacl" .
melod:Item a melod:Entity ;
    rdfs:label "Item"@en ;
    melod_ui:entity_folder_name "items" ;
    melod_ui:shacl_file_location "configuration/item.shacl" .
melod:Expression a melod:Entity ;
    rdfs:label "Expression"@en ;
    melod_ui:entity_folder_name "expressions" ;
    melod_ui:shacl_file_location "configuration/expression.shacl" .
melod:Instrumentation a melod:Entity ;
    rdfs:label "Instrumentation"@en ;
    melod_ui:entity_folder_name "instrumentations" ;
    melod_ui:shacl_file_location "configuration/instrumentation.shacl" .
melod:Work a melod:Entity ;
    rdfs:label "Work"@en ;
    melod_ui:entity_folder_name "works" ;
    melod_ui:shacl_file_location "configuration/work.shacl" .
